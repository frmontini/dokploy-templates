# Psono domain and web client
# Keep all three domain fields equal so the register/backend domain matches the server domain.
PSONO_DOMAIN=vault.example.com
PSONO_USER_DOMAIN=vault.example.com
PSONO_ALLOWED_DOMAINS=vault.example.com
PSONO_TITLE=Psono Vault
PSONO_ALLOW_REGISTRATION=true
PSONO_ALLOW_LOST_PASSWORD=false

# PostgreSQL
POSTGRES_DB=psono
POSTGRES_USER=psono
POSTGRES_PASSWORD=REPLACE_WITH_GENERATED_PASSWORD

# Brevo API email backend, not SMTP
PSONO_EMAIL_BACKEND=anymail.backends.brevo.EmailBackend
PSONO_EMAIL_FROM=no-reply@example.com
PSONO_BREVO_API_KEY=REPLACE_WITH_BREVO_API_KEY
PSONO_BREVO_API_URL=https://api.brevo.com/v3/
PSONO_ANYMAIL_IGNORE_UNSUPPORTED_FEATURES=True

# Generated by psono-keygen. Do not regenerate after storing real vault data.
PSONO_SECRET_KEY=REPLACE_WITH_GENERATED_VALUE
PSONO_PRIVATE_KEY=REPLACE_WITH_GENERATED_VALUE
PSONO_PUBLIC_KEY=REPLACE_WITH_GENERATED_VALUE
PSONO_ACTIVATION_LINK_SECRET=REPLACE_WITH_GENERATED_VALUE
PSONO_DB_SECRET=REPLACE_WITH_GENERATED_VALUE

# Important:
# In Dokploy / Compose env input, this value must be escaped with double dollars.
# The keygen already prints it correctly for copy/paste, for example:
# PSONO_EMAIL_SECRET_SALT=$$2b$$12$$REPLACE_WITH_GENERATED_VALUE
# Inside the running container it must appear as:
# PSONO_EMAIL_SECRET_SALT=$2b$12$REPLACE_WITH_GENERATED_VALUE
PSONO_EMAIL_SECRET_SALT=$$2b$$12$$REPLACE_WITH_GENERATED_VALUE
